# Public domain
SITE_DOMAIN=tesst.linuxunity.com
SITE_WWW_DOMAIN=www.tesst.linuxunity.com
NEXT_PUBLIC_SITE_URL=https://tesst.linuxunity.com
NEXT_REVALIDATE_SECRET=change-this-revalidate-secret

# Public bind for the Docker Nginx container. The container is the public
# reverse proxy and terminates HTTPS after Let's Encrypt certificates are issued.
NGINX_HTTP_BIND=0.0.0.0:80
NGINX_HTTPS_BIND=0.0.0.0:443
NGINX_DIAGNOSTIC_BIND=127.0.0.1:8080

# AWS ECR image used by production Docker Compose
AWS_DEFAULT_REGION=ap-southeast-1
AWS_ECR_REGISTRY=123456789012.dkr.ecr.ap-southeast-1.amazonaws.com
AWS_ECR_REPOSITORY=cloud-devops-blog
APP_IMAGE=123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/cloud-devops-blog:production

# Uptime Kuma
KUMA_DOMAIN=kuma.linuxunity.com

# WordPress public URL. Keep this as the same-domain HTTPS URL because
# Nginx routes /wp-admin, /wp-json, and WordPress assets to the WordPress container.
WORDPRESS_SITE_URL=https://tesst.linuxunity.com
NEXT_PUBLIC_WORDPRESS_PUBLIC_URL=https://tesst.linuxunity.com

# Comma-separated old WordPress origins whose /wp-content and /wp-includes
# assets should be rewritten to NEXT_PUBLIC_WORDPRESS_PUBLIC_URL at runtime.
WORDPRESS_LEGACY_ASSET_ORIGINS=https://linuxunity.com,https://www.linuxunity.com
NEXT_PUBLIC_WORDPRESS_LEGACY_ASSET_ORIGINS=https://linuxunity.com,https://www.linuxunity.com

# WordPress database credentials
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-this-wordpress-db-password
MARIADB_ROOT_PASSWORD=change-this-mariadb-root-password
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=0
WORDPRESS_MEMORY_LIMIT=256M

# Next.js and scripts use this internal WordPress REST API target inside Docker.
# The query route works even when Apache/WordPress rewrite rules have not created /wp-json.
# The public browser never sees this value.
WORDPRESS_API_BASE=http://wordpress?rest_route=/wp/v2

# Optional: automatically translate legacy Vietnamese-only posts when serving /en.
# Uses the OpenAI Responses API server-side and caches translations in Redis when REDIS_URL is set.
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-5.5
# Optional custom Responses-compatible endpoint for proxies/tests.
OPENAI_TRANSLATION_BASE_URL=https://api.openai.com/v1/responses

# Keep false by default. When false, old WordPress image URLs remain on their
# original host unless the import/normalize scripts have localized them. Set true
# only if you have copied old /wp-content uploads into the new WordPress uploads.
REWRITE_LEGACY_WORDPRESS_ASSETS=false
NEXT_PUBLIC_REWRITE_LEGACY_WORDPRESS_ASSETS=false

# Optional scripts: import/list roadmap drafts through the WordPress REST API.
# Use a WordPress Application Password for an administrator/editor account,
# not your normal login password.
WORDPRESS_URL=https://tesst.linuxunity.com
WORDPRESS_USERNAME=admin-user
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx-xxxx-xxxx

# Keep false. The import script is create-only and refuses destructive imports.
WORDPRESS_DELETE_EXISTING_POSTS=false
WORDPRESS_WRITE_META=false
ROADMAP_WORDPRESS_MANIFEST=content/roadmap-draft-posts.wordpress.json

# WordPress-to-WordPress legacy import options.
# IMPORT_MEDIA=true downloads images from the old site and uploads them to the target WordPress media library.
IMPORT_MEDIA=true

# Optional WP-CLI helper variables for first admin creation/reset.
# Do not commit real values in .env.
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change-this-wordpress-admin-password
WP_ADMIN_EMAIL=admin@tesst.linuxunity.com
