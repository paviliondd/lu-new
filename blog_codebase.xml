<file path="deploy/nginx/default.conf">
map $arg_rest_route $wordpress_rest_query {
    default 1;
    "" 0;
}

map $uri $wordpress_path {
    default 0;
    ~^/wp-admin 1;
    ~^/wp-login\.php$ 1;
    ~^/wp-json 1;
    ~^/wp-content 1;
    ~^/wp-includes 1;
    ~^/wp-cron\.php$ 1;
    ~^/wp-comments-post\.php$ 1;
    ~^/wp-.*\.php$ 1;
    ~^/index\.php$ 1;
    ~^/xmlrpc\.php$ 1;
}

map "$wordpress_rest_query:$wordpress_path" $proxy_target {
    default http://app:3000;
    ~^1: http://wordpress:80;
    ~^0:1$ http://wordpress:80;
}

map $http_x_forwarded_proto $forwarded_proto {
    default $scheme;
    https https;
    http http;
}

map $http_upgrade $connection_upgrade {
    default upgrade;
    "" close;
}

server {
    listen 80;
    server_name kuma.linuxunity.com;

