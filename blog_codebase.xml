<file path=".env.example">
# Public domain
SITE_DOMAIN=tesst.linuxunity.com
SITE_WWW_DOMAIN=www.tesst.linuxunity.com
NEXT_PUBLIC_SITE_URL=https://tesst.linuxunity.com

# Public bind for the Docker Nginx container. Use 0.0.0.0:80 when the
# container is the public reverse proxy, or 127.0.0.1:8080 when a host Nginx
# proxies traffic into Docker.
NGINX_HTTP_BIND=0.0.0.0:80
NGINX_DIAGNOSTIC_BIND=127.0.0.1:8080

# AWS ECR image used by production Docker Compose
AWS_DEFAULT_REGION=ap-southeast-1
AWS_ECR_REGISTRY=123456789012.dkr.ecr.ap-southeast-1.amazonaws.com
AWS_ECR_REPOSITORY=cloud-devops-blog
APP_IMAGE=123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/cloud-devops-blog:production

# Uptime Kuma
KUMA_DOMAIN=kuma.linuxunity.com

# WordPress public URL. Keep this as the same-domain HTTPS URL because
# Nginx routes /wp-admin, /wp-json, and WordPress assets to the WordPress container.
WORDPRESS_SITE_URL=https://tesst.linuxunity.com
NEXT_PUBLIC_WORDPRESS_PUBLIC_URL=https://tesst.linuxunity.com

# Comma-separated old WordPress origins whose /wp-content and /wp-includes
# assets should be rewritten to NEXT_PUBLIC_WORDPRESS_PUBLIC_URL at runtime.
WORDPRESS_LEGACY_ASSET_ORIGINS=https://linuxunity.com,https://www.linuxunity.com
NEXT_PUBLIC_WORDPRESS_LEGACY_ASSET_ORIGINS=https://linuxunity.com,https://www.linuxunity.com

# WordPress database credentials
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-this-wordpress-db-password
MARIADB_ROOT_PASSWORD=change-this-mariadb-root-password
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=0
WORDPRESS_MEMORY_LIMIT=256M

# Next.js and scripts use this internal WordPress REST API target inside Docker.
# The query route works even when Apache/WordPress rewrite rules have not created /wp-json.
# The public browser never sees this value.
WORDPRESS_API_BASE=http://wordpress?rest_route=/wp/v2

# Optional scripts: import/list roadmap drafts through the WordPress REST API.
# Use a WordPress Application Password for an administrator/editor account,
# not your normal login password.
WORDPRESS_URL=https://tesst.linuxunity.com
WORDPRESS_USERNAME=admin-user
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx-xxxx-xxxx

# Keep false. The import script is create-only and refuses destructive imports.
WORDPRESS_DELETE_EXISTING_POSTS=false
WORDPRESS_WRITE_META=false
ROADMAP_WORDPRESS_MANIFEST=content/roadmap-draft-posts.wordpress.json

# Optional WP-CLI helper variables for first admin creation/reset.
# Do not commit real values in .env.
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change-this-wordpress-admin-password
WP_ADMIN_EMAIL=admin@tesst.linuxunity.com
</file>

<file path="docker-compose.yml">
services:
  nginx:
    image: nginx:1.27-alpine
    restart: unless-stopped
    depends_on:
      app:
        condition: service_healthy
      wordpress:
        condition: service_healthy
      uptime-kuma:
        condition: service_started
    ports:
      - "${NGINX_HTTP_BIND:-0.0.0.0:80}:80"
      - "${NGINX_DIAGNOSTIC_BIND:-127.0.0.1:8080}:80"
    volumes:
      - ./deploy/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - public
      - internal

  app:
    image: ${APP_IMAGE:-cloud-devops-blog-app:production}
    restart: unless-stopped
    env_file:
      - .env
    environment:
      NODE_ENV: production
      WORDPRESS_API_BASE: "http://wordpress?rest_route=/wp/v2"
      NEXT_PUBLIC_SITE_URL: https://${SITE_DOMAIN}
      NEXT_PUBLIC_WORDPRESS_PUBLIC_URL: ${NEXT_PUBLIC_WORDPRESS_PUBLIC_URL:-https://${SITE_DOMAIN}}
    depends_on:
      wordpress:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:3000/api/health >/dev/null || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
    expose:
      - "3000"
    networks:
      - internal

  uptime-kuma:
    image: louislam/uptime-kuma:1.23.16
    restart: unless-stopped
    volumes:
      - uptime_kuma_data:/app/data
    expose:
      - "3001"
    networks:
      - internal

  wordpress:
    image: wordpress:6.8-php8.3-apache
    restart: unless-stopped
    env_file:
      - .env
    environment:
      WORDPRESS_DB_HOST: db:3306
      WORDPRESS_DB_NAME: ${WORDPRESS_DB_NAME}
      WORDPRESS_DB_USER: ${WORDPRESS_DB_USER}
      WORDPRESS_DB_PASSWORD: ${WORDPRESS_DB_PASSWORD}
      WORDPRESS_TABLE_PREFIX: ${WORDPRESS_TABLE_PREFIX}
      WORDPRESS_DEBUG: ${WORDPRESS_DEBUG}
      WORDPRESS_CONFIG_EXTRA: |
        define('WP_HOME', '${WORDPRESS_SITE_URL}');
        define('WP_SITEURL', '${WORDPRESS_SITE_URL}');
        define('FORCE_SSL_ADMIN', true);
        define('DISALLOW_FILE_EDIT', true);
        define('WP_MEMORY_LIMIT', '${WORDPRESS_MEMORY_LIMIT}');
        if (isset($$_SERVER['HTTP_X_FORWARDED_PROTO']) && $$_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https') {
          $$_SERVER['HTTPS'] = 'on';
        }
        if (!isset($$_SERVER['HTTP_AUTHORIZATION']) && isset($$_SERVER['REDIRECT_HTTP_AUTHORIZATION'])) {
          $$_SERVER['HTTP_AUTHORIZATION'] = $$_SERVER['REDIRECT_HTTP_AUTHORIZATION'];
        }
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - wordpress_data:/var/www/html
      - ./deploy/wordpress/uploads.ini:/usr/local/etc/php/conf.d/uploads.ini:ro
      - ./deploy/wordpress/authorization.conf:/etc/apache2/conf-enabled/authorization.conf:ro
    healthcheck:
      test: ["CMD-SHELL", "php -r 'exit(@fsockopen(\"127.0.0.1\", 80) ? 0 : 1);'"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 60s
    expose:
      - "80"
    networks:
      - internal

  db:
    image: mariadb:11.4
    restart: unless-stopped
    command: --transaction-isolation=READ-COMMITTED --binlog-format=ROW
    env_file:
      - .env
    environment:
      MARIADB_DATABASE: ${WORDPRESS_DB_NAME}
      MARIADB_USER: ${WORDPRESS_DB_USER}
      MARIADB_PASSWORD: ${WORDPRESS_DB_PASSWORD}
      MARIADB_ROOT_PASSWORD: ${MARIADB_ROOT_PASSWORD}
    volumes:
      - db_data:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mariadb-admin ping -h 127.0.0.1 -u\"$${MARIADB_USER}\" -p\"$${MARIADB_PASSWORD}\" --silent"]
      interval: 30s
      timeout: 5s
      retries: 10
      start_period: 60s
    networks:
      - internal

  wpcli:
    image: wordpress:cli-php8.3
    profiles:
      - tools
    env_file:
      - .env
    environment:
      WORDPRESS_DB_HOST: db:3306
      WORDPRESS_DB_NAME: ${WORDPRESS_DB_NAME}
      WORDPRESS_DB_USER: ${WORDPRESS_DB_USER}
      WORDPRESS_DB_PASSWORD: ${WORDPRESS_DB_PASSWORD}
      WORDPRESS_TABLE_PREFIX: ${WORDPRESS_TABLE_PREFIX}
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - wordpress_data:/var/www/html
    user: "33:33"
    entrypoint: ["wp"]
    command: ["--info"]
    networks:
      - internal

volumes:
  wordpress_data:
  db_data:
  uptime_kuma_data:

networks:
  public:
  internal:
</file>

